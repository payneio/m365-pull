# Vite env vars for MSAL configuration.
#
# Copy this file to `.env.local` and fill in the values from your own
# Entra app registration. `.env.local` is gitignored so your IDs stay
# off GitHub. Anything prefixed with `VITE_` is exposed to client code
# at build time via `import.meta.env.VITE_*`.
#
# See README.md "First-time setup" for how to create the app registration,
# configure redirect URIs, and request the Microsoft Graph permissions
# this SPA needs.

# Application (client) ID from your Entra app registration.
VITE_MSAL_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Directory (tenant) ID of your Microsoft 365 tenant.
VITE_MSAL_TENANT_ID=00000000-0000-0000-0000-000000000000
